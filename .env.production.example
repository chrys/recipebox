# Copy this file to /srv/recipes/.env on the server and fill in the values.
# Never commit the real .env to version control.

DJANGO_SETTINGS_MODULE=recipebox.settings.production

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=replace-me-with-a-long-random-string

# Postgres credentials (created per instructions in README / deployment guide)
DB_NAME=recipes
DB_USER=recipes
DB_PASSWORD=replace-me-with-a-strong-password
DB_HOST=localhost
DB_PORT=5432

# Optional: set to DEBUG for more verbose Django logging
DJANGO_LOG_LEVEL=WARNING
